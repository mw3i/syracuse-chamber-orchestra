  "conductor": {
    "slug": "victor-vallo",
    "name": "Dr. Victor Vallo Jr.",
    "role": "Music Director & Conductor",
    "image": "musician-victor-vallo",
    "bioSummary": "Dr. Victor Vallo Jr. is Adjunct Instructor in Trumpet at Le Moyne College and Music Director of the Syracuse Chamber Orchestra. His career spans teaching trumpet, music education, orchestra, and band at colleges and universities across the country.",
    "bioParagraphs": [
      "He has held faculty and chair roles at the College of Saint Rose, Newberry College, Georgia College & State University, Immaculata University, Anderson University, Jacksonville State University, and Southern Arkansas University. He earned degrees from Syracuse University, George Washington University, and the University of Florida, where he was Graduate Teaching Assistant for the band and orchestra programs.",
      "A trumpeter and cellist, Dr. Vallo has music-directed orchestras including the Newberry Chamber Orchestra, Oconee Regional Symphony Orchestra, Anderson Symphony Orchestra, Alabama and South Carolina All-State Orchestras, and festival ensembles across the Northeast and Southeast."
    ]
  },
